{
  "name": "groq-ollama-proxy",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Ollama-compatible proxy server backed by Groq.",
  "type": "module",
  "scripts": {
    "dev:mcp": "tsx src/mcp.ts",
